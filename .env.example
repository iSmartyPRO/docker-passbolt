# =============================================================================
# Passbolt CE — sample configuration (copy to .env and fill in)
# =============================================================================

# --- Application ---
APP_FULL_BASE_URL=https://pass.example.com
DOCKER_CONTAINER_NAME=pass
DOCKER_HTTP_PORT=8088
DOCKER_HTTPS_PORT=8089

# --- Database (MariaDB/MySQL) ---
DATASOURCES_DEFAULT_HOST=mariadb
DATASOURCES_DEFAULT_PORT=3306
DATASOURCES_DEFAULT_USERNAME=passbolt_user
DATASOURCES_DEFAULT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATASOURCES_DEFAULT_DATABASE=passbolt

# --- Email (SMTP) ---
EMAIL_DEFAULT_FROM_NAME=Passbolt
EMAIL_DEFAULT_FROM=passbolt@example.com
EMAIL_TRANSPORT_DEFAULT_HOST=smtp.example.com
EMAIL_TRANSPORT_DEFAULT_PORT=587
EMAIL_TRANSPORT_DEFAULT_USERNAME=passbolt@example.com
EMAIL_TRANSPORT_DEFAULT_PASSWORD=CHANGE_ME_SMTP_PASSWORD
EMAIL_TRANSPORT_DEFAULT_TLS=true

# --- Passbolt ---
PASSBOLT_FULL_BASE_URL=https://pass.example.com
# Server GPG key fingerprint (required; see installation documentation)
PASSBOLT_GPG_SERVER_KEY_FINGERPRINT=YOUR_GPG_SERVER_KEY_FINGERPRINT
PASSBOLT_SSL_FORCE=false
PASSBOLT_TRUST_PROXY=true
PASSBOLT_SECURITY_PROXIES_ACTIVE=true
PASSBOLT_CHECK_DOMAIN_MISMATCH=false
PASSBOLT_SECURITY_SMTP_SETTINGS_ENDPOINTS_DISABLED=false

# Verify SMTP TLS certificate (false for self-signed / internal CA)
PASSBOLT_PLUGINS_SMTP_SETTINGS_SECURITY_SSL_VERIFY_PEER=false
PASSBOLT_PLUGINS_SMTP_SETTINGS_SECURITY_SSL_VERIFY_PEER_NAME=false
PASSBOLT_PLUGINS_SMTP_SETTINGS_SECURITY_SSL_ALLOW_SELF_SIGNED=true

# --- Docker ---
# External Docker network name (create with: docker network create <name>)
DOCKER_NETWORK_NAME=docker-lan
# Path to trusted CA certificate (optional). Default: ./ssl/custom.crt
# SSL_CA_CERT_PATH=./ssl/custom.crt

# --- Backups ---
BACKUP_DAYS=7
# If the DB runs in Docker, dump via docker exec (DB hostname may not resolve from host)
# BACKUP_DB_CONTAINER=mariadb
# Recipient for latest backup email (scripts/send-backup-email.sh)
BACKUP_EMAIL_TO=admin@example.com
# Cron schedules (defaults: backup 02:00 daily, email 03:00 Sundays). Set via scripts/install-cron.sh
# BACKUP_CRON_SCHEDULE="0 2 * * *"
# BACKUP_EMAIL_CRON_SCHEDULE="0 3 * * 0"
